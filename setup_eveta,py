import os
import subprocess
import sys

def run_realtime(command):
    """Ejecuta un comando y muestra la salida en vivo."""
    print(f"\n>>> EJECUTANDO: {command}\n" + "-"*40)
    process = subprocess.Popen(
        command, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True
    )
    
    # Lee la salida línea por línea mientras el proceso corre
    for line in process.stdout:
        print(line, end="") # Aquí es donde verás el progreso real
        sys.stdout.flush()
        
    process.wait()
    if process.returncode != 0:
        print(f"\n❌ ERROR en el comando: {command}")
        sys.exit(1)

